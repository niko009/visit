---
/**
 * Страница "Контакты"
 * 
 * Содержит:
 * - Контактную информацию (телефон, email, адрес, соцсети)
 * - Форму обратной связи
 * - Карту с расположением салона
 * - Время работы
 */

import Layout from '@/layouts/Layout.astro';

// SEO мета-данные
const pageTitle = 'Контакты';
const pageDescription = 'Свяжитесь с нами по телефону, email или через форму обратной связи. Мы находимся в центре города и работаем без выходных.';

// Контактные данные (в будущем можно вынести в Content Collection)
const contacts = {
  phone: '+7 (999) 123-45-67',
  phoneLink: 'tel:+79991234567',
  email: 'info@beauty-salon.ru',
  address: 'г. Москва, ул. Примерная, д. 10, офис 5',
  workingHours: {
    weekdays: 'Пн-Пт: 10:00 — 21:00',
    weekends: 'Сб-Вс: 11:00 — 20:00',
  },
  socials: {
    instagram: 'https://instagram.com/beauty_salon',
    telegram: 'https://t.me/beauty_salon',
    whatsapp: 'https://wa.me/79991234567',
  },
};
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Hero секция -->
  <section class="bg-gradient-to-br from-blue-50 to-indigo-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="mb-4 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
          Свяжитесь с нами
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-gray-600">
          Мы всегда рады ответить на ваши вопросы и помочь с выбором услуги.
          Свяжитесь с нами удобным для вас способом.
        </p>
      </div>
    </div>
  </section>

  <!-- Основной контент -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Левая колонка: Контактная информация -->
        <div class="space-y-8">
          <!-- Блок: Связь с нами -->
          <div>
            <h2 class="mb-6 text-2xl font-bold text-gray-900">
              Наши контакты
            </h2>
            
            <div class="space-y-4">
              <!-- Телефон -->
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-blue-100">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 text-blue-600"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="mb-1 text-sm font-medium text-gray-500">Телефон</h3>
                  <a
                    href={contacts.phoneLink}
                    class="text-lg font-semibold text-gray-900 transition-colors hover:text-blue-600"
                  >
                    {contacts.phone}
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-blue-100">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 text-blue-600"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="mb-1 text-sm font-medium text-gray-500">Email</h3>
                  <a
                    href={`mailto:${contacts.email}`}
                    class="text-lg font-semibold text-gray-900 transition-colors hover:text-blue-600"
                  >
                    {contacts.email}
                  </a>
                </div>
              </div>

              <!-- Адрес -->
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-blue-100">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 text-blue-600"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="mb-1 text-sm font-medium text-gray-500">Адрес</h3>
                  <p class="text-lg font-semibold text-gray-900">
                    {contacts.address}
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Время работы -->
          <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50 p-6">
            <h3 class="mb-4 text-xl font-bold text-gray-900">
              Время работы
            </h3>
            <div class="space-y-2">
              <div class="flex justify-between">
                <span class="text-gray-700">Понедельник — Пятница</span>
                <span class="font-semibold text-gray-900">{contacts.workingHours.weekdays.split(': ')[1]}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-700">Суббота — Воскресенье</span>
                <span class="font-semibold text-gray-900">{contacts.workingHours.weekends.split(': ')[1]}</span>
              </div>
            </div>
          </div>

          <!-- Социальные сети -->
          <div>
            <h3 class="mb-4 text-xl font-bold text-gray-900">
              Мы в социальных сетях
            </h3>
            <div class="flex gap-4">
              <!-- Instagram -->
              <a
                href={contacts.socials.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-12 w-12 items-center justify-center rounded-lg bg-gradient-to-br from-purple-600 to-pink-500 text-white transition-transform hover:scale-110 focus:outline-none focus:ring-4 focus:ring-purple-300"
                aria-label="Instagram"
              >
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
                    clip-rule="evenodd"
                  />
                </svg>
              </a>

              <!-- Telegram -->
              <a
                href={contacts.socials.telegram}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-12 w-12 items-center justify-center rounded-lg bg-blue-500 text-white transition-transform hover:scale-110 focus:outline-none focus:ring-4 focus:ring-blue-300"
                aria-label="Telegram"
              >
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"
                  />
                </svg>
              </a>

              <!-- WhatsApp -->
              <a
                href={contacts.socials.whatsapp}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-12 w-12 items-center justify-center rounded-lg bg-green-500 text-white transition-transform hover:scale-110 focus:outline-none focus:ring-4 focus:ring-green-300"
                aria-label="WhatsApp"
              >
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Правая колонка: Форма обратной связи -->
        <div>
          <div class="rounded-2xl bg-white p-8 shadow-lg">
            <h2 class="mb-6 text-2xl font-bold text-gray-900">
              Форма обратной связи
            </h2>
            
            <form class="space-y-6" method="POST" action="/api/contact">
              <!-- Имя -->
              <div>
                <label for="name" class="mb-2 block text-sm font-medium text-gray-700">
                  Ваше имя <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-lg border border-gray-300 px-4 py-3 transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
                  placeholder="Иван Иванов"
                />
              </div>

              <!-- Телефон -->
              <div>
                <label for="phone" class="mb-2 block text-sm font-medium text-gray-700">
                  Телефон <span class="text-red-500">*</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full rounded-lg border border-gray-300 px-4 py-3 transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
                  placeholder="+7 (999) 123-45-67"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="mb-2 block text-sm font-medium text-gray-700">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full rounded-lg border border-gray-300 px-4 py-3 transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
                  placeholder="example@mail.ru"
                />
              </div>

              <!-- Сообщение -->
              <div>
                <label for="message" class="mb-2 block text-sm font-medium text-gray-700">
                  Сообщение <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full rounded-lg border border-gray-300 px-4 py-3 transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
                  placeholder="Расскажите, чем мы можем помочь..."
                ></textarea>
              </div>

              <!-- Согласие на обработку данных -->
              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="consent"
                  name="consent"
                  required
                  class="mt-1 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-2 focus:ring-blue-500"
                />
                <label for="consent" class="text-sm text-gray-600">
                  Я согласен на обработку персональных данных в соответствии с 
                  <a href="/privacy" class="text-blue-600 underline hover:text-blue-700">
                    политикой конфиденциальности
                  </a>
                </label>
              </div>

              <!-- Кнопка отправки -->
              <button
                type="submit"
                class="w-full rounded-lg bg-blue-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-300"
              >
                Отправить сообщение
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Карта -->
  <section class="bg-gray-100 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-3xl font-bold text-gray-900">
        Как нас найти
      </h2>
      
      <!-- Карта-заглушка (интегрируйте Яндекс.Карты или Google Maps) -->
      <div class="overflow-hidden rounded-2xl shadow-lg">
        <div class="aspect-[16/9] w-full bg-gradient-to-br from-gray-300 to-gray-400">
          <!-- TODO: Интегрировать Яндекс.Карты или Google Maps -->
          <div class="flex h-full items-center justify-center">
            <div class="text-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="mx-auto mb-4 h-16 w-16 text-gray-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                />
              </svg>
              <p class="text-lg font-semibold text-gray-700">
                Карта будет скоро добавлена
              </p>
              <p class="mt-2 text-sm text-gray-600">
                {contacts.address}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA секция -->
  <section class="bg-blue-600 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 text-3xl font-bold text-white">
        Готовы преобразиться?
      </h2>
      <p class="mb-8 text-lg text-blue-100">
        Запишитесь на консультацию прямо сейчас, и мы поможем выбрать идеальную услугу
      </p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={contacts.phoneLink}
          class="inline-block rounded-lg bg-white px-8 py-3 font-semibold text-blue-600 transition-transform hover:scale-105 focus:outline-none focus:ring-4 focus:ring-blue-300"
        >
          Позвонить нам
        </a>
        <a
          href="/services"
          class="inline-block rounded-lg border-2 border-white px-8 py-3 font-semibold text-white transition-transform hover:scale-105 focus:outline-none focus:ring-4 focus:ring-blue-300"
        >
          Посмотреть услуги
        </a>
      </div>
    </div>
  </section>
</Layout>
