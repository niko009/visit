---
import Layout from '@/layouts/Layout.astro';
import { SiteHeader } from '@/react/SiteHeader';
import { HeroSection } from '@/react/HeroSection';
import { StatsSection } from '@/react/StatsSection';
import { AboutSection } from '@/react/AboutSection';
import { ServicesList } from '@/react/ServicesList';
import { MastersList } from '@/react/MastersList';
import { GallerySection } from '@/react/GallerySection';
import { SiteFooter } from '@/react/SiteFooter';
import { getCollection } from 'astro:content';
import type { Service } from '@/react/ServicesList';
import type { Master } from '@/react/MastersList';

// Получаем данные из Content Collections
const servicesCollection = await getCollection('services');
const mastersCollection = await getCollection('masters');
const galleryCollection = await getCollection('gallery');

// Преобразуем в подходящие типы
const services: Service[] = servicesCollection.map((s: any) => ({
  id: s.id,
  data: {
    name: s.data.name,
    description: s.data.description,
    price: s.data.price,
    duration: s.data.duration,
    image: typeof s.data.image === 'string' ? s.data.image : s.data.image.src,
    order: s.data.order,
    isActive: s.data.isActive,
  },
}));

const masters: Master[] = mastersCollection.map((m: any) => ({
  id: m.id,
  data: {
    name: m.data.name,
    position: m.data.position,
    experience: m.data.experience,
    bio: m.data.bio,
    photo: typeof m.data.photo === 'string' ? m.data.photo : m.data.photo.src,
    instagram: m.data.instagram,
    telegram: m.data.telegram,
    order: m.data.order,
    isActive: m.data.isActive,
  },
}));

// Сортируем по порядку
const sortedServices = services.sort((a: Service, b: Service) => (a.data.order || 0) - (b.data.order || 0));
const sortedMasters = masters.sort((a: Master, b: Master) => (a.data.order || 0) - (b.data.order || 0));
const sortedGallery = galleryCollection.sort((a: any, b: any) => (a.data.order || 0) - (b.data.order || 0));

// Готовим данные галереи
const galleryImages = sortedGallery.map((item: any) => ({
  src: typeof item.data.imageAfter === 'string' ? item.data.imageAfter : item.data.imageAfter.src,
  alt: item.data.title,
}));

// Статистика
const stats = [
  { value: '500+', label: 'Довольных клиентов' },
  { value: '8+', label: 'Лет опыта' },
  { value: '100%', label: 'Стерильность' },
  { value: '24/7', label: 'В социальных сетях' },
];

const pageTitle = 'Brow & Lip Studio - Перманентный макияж';
const pageDescription = 'Профессиональные услуги перманентного макияжа бровей и губ от сертифицированных мастеров. Естественная красота надолго.';

const heroTitle = 'Естественная красота надолго';
const heroDescription = 'Перманентный макияж бровей и губ от сертифицированных мастеров. Подчёркиваем вашу природную красоту с помощью авторских техник и премиальных пигментов.';

const aboutTitle = 'Красота, которой вы доверяете';
const aboutDescription = [
  'Brow & Lip Studio — это пространство, созданное для тех, кто хочет подчеркнуть свою природную красоту. Мы специализируемся на перманентном макияже бровей и губ, используя современные техники, которые дарят максимально естественный результат.',
  'Каждая процедура начинается с детальной консультации и построения индивидуальной формы, чтобы результат идеально подходил именно вам.',
];

// Development mode indicator
const isDev = import.meta.env.DEV;
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Development Admin Panel Link -->
  {isDev && (
    <div class="fixed bottom-4 right-4 z-50">
      <a
        href="/admin"
        class="flex items-center gap-2 rounded-full bg-purple-600 px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:bg-purple-700 hover:scale-105"
        title="Открыть админ-панель TinaCMS"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
        </svg>
        <span>Админка</span>
      </a>
    </div>
  )}

  {/* Header */}
  <SiteHeader client:load />

  {/* Hero Section */}
  <HeroSection
    client:visible
    title={heroTitle}
    description={heroDescription}
    backgroundImage="/images/hero.jpg"
    ctaText="Записаться на консультацию"
    ctaHref="#booking"
    secondaryCTA={{
      text: 'Наши услуги',
      href: '#services',
    }}
  />

  {/* Stats Section */}
  <StatsSection client:visible stats={stats} />

  {/* About Section */}
  <AboutSection
    client:visible
    image="/images/about.jpg"
    title={aboutTitle}
    description={aboutDescription}
  />

  {/* Services Section */}
  <ServicesList client:visible services={sortedServices} />

  {/* Masters Section */}
  <MastersList client:visible masters={sortedMasters} />

  {/* Gallery Section */}
  {galleryImages.length > 0 && <GallerySection client:visible images={galleryImages} />}

  {/* Footer */}
  <SiteFooter client:load />
</Layout>
