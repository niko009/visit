---
/**
 * BeforeAfterCard Component
 * 
 * Карточка для отображения фото "до/после" в галерее
 * 
 * Принципы:
 * - Использует типизированные данные из Content Collection
 * - Оптимизирует изображения через <Image /> компонент
 * - Интерактивный слайдер для сравнения фото
 * - Семантичная HTML5 разметка (article)
 */

import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  // Типизированный объект работы из Content Collection
  item: CollectionEntry<'gallery'>;
}

const { item } = Astro.props;

// Деструктуризация данных для удобства
const { title, category, description, imageBefore, imageAfter, masterName, date } = item.data;

// Маппинг категорий на русские названия
const categoryNames: Record<string, string> = {
  brouws: 'Брови',
  lips: 'Губы',
  eyeliner: 'Межресничка',
  nails: 'Ногти',
  face: 'Уход за лицом',
  other: 'Другое',
};

// Маппинг категорий на цвета
const categoryColors: Record<string, string> = {
  brouws: 'bg-purple-100 text-purple-700',
  lips: 'bg-pink-100 text-pink-700',
  eyeliner: 'bg-blue-100 text-blue-700',
  nails: 'bg-rose-100 text-rose-700',
  face: 'bg-green-100 text-green-700',
  other: 'bg-gray-100 text-gray-700',
};

// Форматирование даты
const formatDate = (date?: Date): string => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('ru-RU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<!-- 
  Семантичный <article> для карточки галереи
  Адаптивная сетка через Tailwind Grid
-->
<article
  class="group overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-300 hover:shadow-xl"
  role="article"
  aria-label={`Работа: ${title}`}
>
  <!-- Контейнер для сравнения фото -->
  <div class="relative aspect-square overflow-hidden bg-gray-100">
    <!-- Фото "После" (фон) -->
    <div class="absolute inset-0">
      <Image
        src={imageAfter}
        alt={`${title} - После`}
        class="h-full w-full object-cover"
        widths={[400, 600, 800]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Фото "До" (перекрывающий слой) -->
    <div class="absolute inset-0 gallery-before-layer">
      <Image
        src={imageBefore}
        alt={`${title} - До`}
        class="h-full w-full object-cover"
        widths={[400, 600, 800]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Разделительная линия -->
    <div class="absolute inset-y-0 left-1/2 w-0.5 bg-white shadow-lg gallery-divider"></div>

    <!-- Маркеры "До" и "После" -->
    <div class="absolute top-4 left-4 z-10">
      <span class="rounded-full bg-black/70 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
        До
      </span>
    </div>
    <div class="absolute top-4 right-4 z-10">
      <span class="rounded-full bg-black/70 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
        После
      </span>
    </div>

    <!-- Бейдж категории (поверх изображения) -->
    <div class="absolute bottom-4 left-4 z-10">
      <span class={`rounded-full px-3 py-1.5 text-xs font-medium ${categoryColors[category]}`}>
        {categoryNames[category]}
      </span>
    </div>
  </div>

  <!-- Контентная часть карточки -->
  <div class="p-6">
    <!-- Заголовок работы -->
    <h3 class="mb-2 text-lg font-semibold text-gray-900">
      {title}
    </h3>

    <!-- Описание -->
    <p class="mb-4 text-sm leading-relaxed text-gray-600 line-clamp-2">
      {description}
    </p>

    <!-- Мета-информация -->
    <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500">
      {masterName && (
        <div class="flex items-center gap-1">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
            />
          </svg>
          <span>{masterName}</span>
        </div>
      )}

      {date && (
        <div class="flex items-center gap-1">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
            />
          </svg>
          <span>{formatDate(date)}</span>
        </div>
      )}
    </div>
  </div>
</article>

<style>
  /* Базовое состояние: фото "До" занимает 50% ширины */
  .gallery-before-layer {
    clip-path: inset(0 50% 0 0);
    transition: clip-path 0.3s ease;
  }

  /* При наведении: показываем больше "После" */
  article:hover .gallery-before-layer {
    clip-path: inset(0 70% 0 0);
  }

  /* Анимация разделительной линии */
  .gallery-divider {
    transition: left 0.3s ease;
  }

  article:hover .gallery-divider {
    left: 30%;
  }
</style>
